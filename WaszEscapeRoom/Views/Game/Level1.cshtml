@{
    Layout = null;
}

<!DOCTYPE html>
<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Document</title>
    <style>
      * {
        overflow: hidden;
      }
      html,
      body {
        height: 100%;
        margin: 0;
      }
      main {
        display: flex;
        flex-direction: row;
        justify-content: center;
        align-items: center;
        height: 100vh;
        width: 100%;
      }
      section {
        height: 100%;
      }
      section:not(#door) {
        flex: 1 1 auto;
        min-width: 0;
      }
      #door {
        flex: 0 0 auto;
      }

      #door {
        display: flex;
        justify-content: center;
        align-items: center;
      }
      object {
        display: block;
      }
      section:not(#door) object {
        width: 100%;
        height: 100%;
      }
      #door object {
        height: 100%;
        width: 100%;
      }
      #dog {
        position: absolute;
        left: 85%;
        bottom: 0;
        transform: translate(-50%, 0);
        width: 10vw;
        height: auto;
      }
    </style>
  </head>
  <body>
    <main>
      <section>
        <object data="/img/bars.svg" type="image/svg+xml"></object>
      </section>
      <section id="door">
        <object data="/img/door.svg" type="image/svg+xml" id="door-svg"></object>
      </section>
      <section>
        <object data="/img/bars.svg" type="image/svg+xml"></object>
      </section>
    </main>
    <object data="/img/dog.svg" type="image/svg+xml" id="dog"></object>
    <form action="/game/level2" method="post" id="next-level-form">
      <input type="hidden" value="" id="code" name="code" />
    </form>
    <script>
      document.addEventListener("DOMContentLoaded", function () {
        const doorObject = document.getElementById("door-svg");
        doorObject.addEventListener("load", function () {
          const svgDoc = doorObject.contentDocument;
          const keypad = svgDoc.getElementById("keypad");
          keypad.addEventListener("click", function () {
            let code = prompt("Enter the 4-digit code:");
            document.getElementById("code").value = code;
            document.getElementById("next-level-form").submit();
          });
        });
        const dogObject = document.getElementById("dog");
        dogObject.addEventListener("load", function () {
          const dogSvgDoc = dogObject.contentDocument;
          const dogRoot = dogSvgDoc.documentElement;
          dogRoot.addEventListener("click", function () {
            alert(
              "hau hau hau hau hau (pauza) hau hau hau hau hauuuuu (pauza) hauuuuu hauuuuu hau hau hau (pauza) hauuuuuhau hau hau hau",
            );
          });
        });
        @if(!ViewData.ModelState.IsValid)
        {
          <text>
            alert("Niepoprawny kod!");
          </text>
        }
      });
    </script>
  </body>
</html>
